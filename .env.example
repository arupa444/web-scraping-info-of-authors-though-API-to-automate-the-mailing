# iceReach configuration — copy to .env and fill in.
#   cp .env.example .env
# .env is gitignored; NEVER commit real secrets. Every value below is optional and
# falls back to the (dev) default shown; override what you need.

# --- Storage -----------------------------------------------------------------
# SQLite by default (file in the working dir). Use Postgres in production:
#   postgresql+psycopg://user:pass@host:5432/icereach
DATABASE_URL=sqlite:///./icereach.db

# --- Security ----------------------------------------------------------------
# REQUIRED in production: a long random string (signs sessions + CSRF tokens).
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Public base URL used to build open/click/unsubscribe links. MUST be the public
# URL real recipients can reach (your deployed host/tunnel). Localhost only works
# for testing on your own machine.
BASE_URL=http://127.0.0.1:8000

# CORS allow-origin for the SPA. Only needed in TWO-PROCESS dev mode, where the
# Vite dev server (default port 5173) calls the API cross-origin. In single-process
# mode (run.py serves the built SPA from the same origin) this is unused.
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Requests per IP per minute on API/public surfaces (429 + Retry-After). 0 = off.
RATE_LIMIT_PER_MINUTE=600

# --- AI (optional) -----------------------------------------------------------
# Enables subjects/body/critique/sequences/analytics narratives. Without it those
# endpoints return HTTP 503 (the rest of the app works fine).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# --- Inbound ESP webhooks (optional; only if you use Resend/SendGrid + webhooks)
# If set, /webhooks/{provider} requires a matching ?secret=... query param.
WEBHOOK_SECRET=

# --- Bounce mailbox / DSN poller (optional) ----------------------------------
# IMAP mailbox that receives SMTP bounce (DSN) messages; the 'poll_dsn' job reads
# it to mark hard/soft bounces and auto-suppress hard bounces.
BOUNCE_IMAP_HOST=
BOUNCE_IMAP_USER=
BOUNCE_IMAP_PASSWORD=

# NOTE: SMTP/ESP sender credentials are NOT set here — you add a "sending domain"
# (host/port/username/password or ESP API key) per workspace inside the app UI.
